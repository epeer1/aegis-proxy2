# Auth0 M2M Application (Token Vault)
AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
AUTH0_CLIENT_ID=your_m2m_client_id
AUTH0_CLIENT_SECRET=your_m2m_client_secret
AUTH0_AUDIENCE=https://dev-xxxxx.us.auth0.com/api/v2/

# Policy Engine LLM (optional — falls back to keyword heuristics if omitted)
# OPENAI_API_KEY=sk-proj-xxxx
# ANTHROPIC_API_KEY=sk-ant-xxxx
# OPENCLAW_API_BASE=http://localhost:8000

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=development

# Dev bypass token (remove in production)
ADMIN_SECRET=local_dev_secret
